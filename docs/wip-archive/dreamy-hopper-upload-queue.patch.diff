+      {fullPageDrop && isWindowDragging && (
+        <div className="pointer-events-none fixed inset-0 z-50 flex items-center justify-center bg-[color:var(--color-bg)]/85 backdrop-blur-sm">
+          <div className="border-[color:var(--color-accent)] bg-[color:var(--color-accent)]/10 text-[color:var(--color-accent)] rounded-2xl border-2 border-dashed px-12 py-10 text-center">
+            <div className="text-5xl">📥</div>
+            <div className="mt-3 text-2xl font-bold">Drop to upload</div>
+            <div className="mt-1 text-sm opacity-80">One or many PDFs — your browser does the rest</div>
+          </div>
+        </div>
+      )}
     </div>
   );
 }
