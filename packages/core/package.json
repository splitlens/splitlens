{
  "name": "@splitlens/core",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Framework-free TypeScript core: parsers, rules, settlement math, encryption.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "// resolution-order": "We point exports at TS source so consumers (apps/web via Next.js transpilePackages) always see the latest code on hot reload, never a stale dist/. Production builds transpile from source too — there's no dist/ in the deploy artifact.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./parsers": {
      "types": "./src/parsers/index.ts",
      "import": "./src/parsers/index.ts"
    },
    "./rules": {
      "types": "./src/rules/index.ts",
      "import": "./src/rules/index.ts"
    },
    "./settlement": {
      "types": "./src/settlement/index.ts",
      "import": "./src/settlement/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@splitlens/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "pdfjs-dist": "^4.10.38",
    "tsx": "^4.22.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
