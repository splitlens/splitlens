{
  "name": "@splitlens/db",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Drizzle ORM schema + migrations for SplitLens. Driver-agnostic (PGlite on web, expo-sqlite on mobile).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@splitlens/tsconfig": "workspace:*",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.3"
  }
}
