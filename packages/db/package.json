{
  "name": "@splitlens/db",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Drizzle ORM schema + better-sqlite3 client for SplitLens. The single on-disk SQLite database is the source of truth for ingested statements; web/CLI consumers read through this package.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@splitlens/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
