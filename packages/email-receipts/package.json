{
  "name": "@splitlens/email-receipts",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Local-first email receipt fetcher. Connects to Gmail (or any IMAP) with an App Password, pulls allowlisted merchant emails, and exposes them to the ingestion pipeline for per-merchant parsing. No third-party servers; nothing leaves the device.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo",
    "spike-fetch": "tsx scripts/spike-fetch.ts",
    "spike-find": "tsx scripts/spike-find-emails.ts"
  },
  "dependencies": {
    "@splitlens/db": "workspace:*",
    "drizzle-orm": "^0.38.4",
    "imapflow": "^1.0.190",
    "mailparser": "^3.7.2"
  },
  "devDependencies": {
    "@splitlens/tsconfig": "workspace:*",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
